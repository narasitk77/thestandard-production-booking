# Production environment — copy to .env and fill in secrets
POSTGRES_DB=production_booking
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

DATABASE_URL=postgresql://postgres:CHANGE_THIS_STRONG_PASSWORD@db:5432/production_booking

NEXT_PUBLIC_APP_URL=http://YOUR_SERVER_IP_OR_DOMAIN
NEXT_PUBLIC_APP_NAME=THE STANDARD Production Booking

APP_PORT=3000
NGINX_PORT=80

UPLOAD_DIR=/app/uploads
