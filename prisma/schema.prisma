generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ShootType {
  STUDIO
  ON_LOCATION
  REMOTE_ONLINE
  EVENT
}

enum Category {
  ORIGINAL_CONTENT
  ADVERTORIAL
  EVENT
  INTERNAL
}

enum BookingStatus {
  REQUESTED
  ASSIGNED
  CONFIRMED
  CANCELLED
  COMPLETED
}

// v1.32.2 — async calendar sync state for CONFIRMED bookings. Updated
// by approve route (PENDING→OK/FAILED), the assign route's auto-recover
// path (OK/FAILED), and the 10-min reconciler worker (OK/FAILED).
enum CalendarSyncStatus {
  PENDING
  OK
  FAILED
}

enum UploadStatus {
  PENDING       // row created by /api/upload/init, awaiting browser to start
  UPLOADING     // at least one cloud upload in progress
  DRIVE_OK      // LEGACY (Wasabi dual-write removed) — Drive done, Wasabi pending
  WASABI_OK     // LEGACY (Wasabi dual-write removed) — Wasabi done, Drive pending
  COMPLETE      // all required destinations done + sheet row appended
  FAILED        // user cancel or confirm timeout — Upload row stays for audit
  ORPHANED      // v1.35 — partial state stuck >24h, reconciler must inspect
}

enum UserRole {
  USER
  COORDINATOR
  MANAGER
  SUPPORT
  ADMIN
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  thaiName   String?  // ชื่อ-นามสกุลภาษาไทย
  nickname   String?  // ชื่อเล่น — shown in the per-outlet Producer dropdown (v1.59)
  employeeId String?  // TSD00xxx
  position   String?  // Producer / Co-Producer / Videographer / etc
  role       UserRole @default(USER)
  active     Boolean  @default(true)

  // Saved e-signature, used to sign OT submissions (requester) and approvals
  // (manager). Stored as a base64-encoded PNG data URL — small image, set once
  // per user at /profile/signature and reused at sign time. A snapshot is
  // embedded into OTRecord on each sign so updating this later does not
  // retroactively change historical signatures.
  signaturePng        String?   @db.Text
  signatureUpdatedAt  DateTime?

  // v1.54.0 — outlets this user produces for (outlet codes, e.g. ["NWS","POP"]).
  // Managed on /admin/permissions; data source for the per-outlet Producer
  // dropdown in the booking form (GET /api/producers). Grants NO access by
  // itself — producer-dashboard access still keys off `position`.
  producerOutlets  String[]  @default([])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("users")
}

// Crew assignment roster shown on /admin/[id] when admin picks who to
// assign to a booking. Previously a hardcoded TEAM constant in
// admin/[id]/page.tsx (v1.30); v1.31 moves it to the DB so the
// roster can be maintained at /admin/team without a code deploy.
//
// `role` is a free-form discriminator that maps to a TeamSection on
// /admin/[id]. Valid values today:
//   producer | video | director | sound | photo | switcher | virtualProduction
// Anything new just appears as its own section once you wire it in
// the page's section list.
//
// `email` is the canonical id (matches assignedEmails on Booking).
// `active=false` hides the member from the assign UI without losing
// historical assignments.
model TeamMember {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String   // display name shown in the assign checkboxes
  role      String   // see comment above for valid values
  active    Boolean  @default(true)
  sort      Int      @default(0)  // tie-breaker within a role group
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("team_members")
  @@index([role, active, sort])
}

enum OTType {
  HOLIDAY  // เสาร์-อาทิตย์ / วันหยุดตามประกาศบริษัท (counts as 1 day)
  OVERTIME // ทำงานเกิน 8 ชั่วโมง (counts hours)
}

enum OTApprovalStatus {
  DRAFT      // user is still filling out — not visible to managers
  SUBMITTED  // user signed and pushed the report; awaiting manager sign-off
  APPROVED   // manager signed off
  REJECTED   // manager pushed back with a rejectionNote; user can edit and resubmit
}

model OTRecord {
  id              String   @id @default(cuid())
  userEmail       String
  month           String   // YYYY-MM, derived from date (the START date)
  date            DateTime @db.Date        // shift START date

  // Task-level fields (new model — required for new entries)
  startTime       String?  @db.VarChar(5)  // HH:MM
  endTime         String?  @db.VarChar(5)  // HH:MM
  // v1.42.0 — overnight OT. When a shift runs past midnight the user sets the
  // END date here; null means it ends the same day as `date`. The OT calc adds
  // (endDate − date) × 24h so the duration is correct across the day boundary.
  // The shift still belongs to its START date for day-type / rate purposes.
  endDate         DateTime? @db.Date
  jobTask         String?  // description of work performed
  justification   String?  // why OT/standby was necessary

  // Approval workflow — see OTApprovalStatus enum for state machine.
  // New records start as DRAFT. User clicks "ส่งให้ approve" → SUBMITTED
  // (snapshots requesterSignaturePng). Manager signs → APPROVED
  // (snapshots approverSignaturePng). Manager pushes back → REJECTED
  // (with rejectionNote). User edits + resubmits → back to SUBMITTED.
  //
  // Signature snapshots are stored on the record itself so that changing
  // the canonical User.signaturePng later does not retroactively change
  // historical OT reports.
  approvalStatus         OTApprovalStatus @default(DRAFT)
  submittedAt            DateTime?
  approvedByEmail        String?
  approvedAt             DateTime?
  requesterSignaturePng  String? @db.Text
  approverSignaturePng   String? @db.Text
  rejectionNote          String?

  // Legacy fields (kept for backward compat with old data; not used for new entries)
  type            OTType?
  hours           Float    @default(0)
  description     String?

  bookingId       String?  // if auto-generated from a booking, the booking id (null = manual)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userEmail, month])
  @@index([month])
  @@index([bookingId])
  @@index([approvalStatus])
  @@map("ot_records")
}

// v1.35.0 — per-outlet upload destination policy. LEGACY: the Wasabi
// dual-write was removed, so the upload flow no longer reads this — kept
// (with existing values) to avoid a destructive migration.
enum StoragePolicy {
  DRIVE_ONLY        // Drive only (the only behavior now)
  DUAL_WRITE        // LEGACY — used to require Drive + Wasabi
}

model Outlet {
  id            String        @id @default(cuid())
  code          String        @unique @db.VarChar(3)
  name          String
  notes         String?
  color         String?
  sort          Int           @default(0)
  storagePolicy StoragePolicy @default(DRIVE_ONLY)
  programs      Program[]
  bookings      Booking[]
  rentalJobs    RentalJob[]

  @@map("outlets")
}

model Program {
  id       String    @id @default(cuid())
  code     String    @db.VarChar(4)
  name     String
  category String
  outlet   Outlet    @relation(fields: [outletId], references: [id])
  outletId String
  episodes Episode[]
  bookings Booking[]

  @@unique([code, outletId])
  @@map("programs")
}

model Booking {
  id               String        @id @default(cuid())
  // Display code = the first episode's episodeId. Same format as Episode.episodeId,
  // so a booking and its episodes share one human-readable namespace. Set after
  // episode creation (so backfill / pre-episode states keep it nullable).
  // Immutable once assigned — never updated when first episode is removed.
  bookingCode      String?       @unique
  shootDate        DateTime      @db.Date
  shootEndDate     DateTime?     @db.Date   // null = single-day shoot
  category         Category
  // Video format/type — free-string to mirror the Producer Dashboard sheet
  // values (Teaser / Highlight, Vlog / On Location, Report (Host + Insert),
  // Interview, Documentary, Commercial, Others). Nullable: pre-existing
  // bookings have none. Independent of `category` (business classification).
  videoType        String?
  shootType        ShootType
  locationName     String?
  callTime         String        @db.VarChar(5)
  estimatedWrap    String?       @db.VarChar(5)
  producer         String   // Content Agency: nickname from _Users tab; other outlets: per-outlet dropdown (v1.59) or free-text name
  producerEmail    String?  // Producer email (canonical id, or free-text email)
  producerPhone    String?  // Producer phone — free-text outlets only (Content Agency uses _Users)
  director         String?  // Director nickname (Content Agency only — null for other outlets)
  directorEmail    String?  // Director email (canonical id)
  // v1.59.0 — Co-Producer for non-Agency outlets, picked from the per-outlet
  // dropdown (same source as Producer). Null when none chosen.
  coProducer       String?
  coProducerEmail  String?
  creative         String[]
  crewRequired     String[]
  videographerCount     Int     @default(1)  // how many videographers requested at booking time
  switcherCount         Int     @default(1)  // how many switchers requested at booking time
  // v1.41.0 — equipment counts surfaced on the calendar event (🎥 / 🎙).
  // Nullable: legacy bookings have none; 0/null both render as "not specified".
  cameraCount      Int?
  micCount         Int?
  // v1.67 — "Block Shot" booking: a flexible-queue shoot where the exact gear
  // isn't pinned down yet, so cameraCount/micCount are NOT required at booking.
  isBlockShot      Boolean @default(false)
  // v1.61.0 — fixed checklist of special gear requested at booking time
  // (Gimbal/Ronin, Prompter, Clip-on Mic, Small Light). Surfaced on the
  // calendar event description + admin detail. Free string[] (no enum) so
  // the option list can grow without a schema change.
  specialEquipment String[]
  // v1.41.0 — LEGACY (replaced by vanCount in v1.131) — off-site shoots that
  // needed a company van. Kept so historical rows aren't dropped; no code
  // writes this anymore.
  needsVan         Boolean       @default(false)
  // v1.131 — how many company vans this shoot needs (0 = none). Replaces the
  // needsVan boolean so multi-van shoots can be booked. When >0 the calendar
  // event title (web + Google) is prefixed with 🚐 (×N when N>1).
  vanCount         Int           @default(0)
  // v1.41.0 — structured freelance crew (name · contract · email). Replaces the
  // old "append into adminNotes text" approach that duplicated names on every
  // re-save (the calendar description is rebuilt from this list, never appended).
  // Shape: [{ name: string, role?: string, phone?: string, contract?: string, email?: string }]
  // (v1.111 added role = 'Photographer'|'Videographer'|'Sound'|'Other' + phone)
  freelancers      Json?
  assignedEmails   String[]
  mainVideographerEmail String?              // designated lead camera, picked at assign-time
  agencyRef        String?
  // Project ID layer — links booking to Producer Dashboard "All Projects".
  // Format PP-YY-NNN (e.g. PP-26-001). Immutable. projectName is a snapshot
  // captured at booking time so we can render without re-fetching the sheet.
  projectId        String?
  projectName      String?
  notes            String?
  adminNotes       String?
  // v1.111 — cached "detect footage" result (folders + Drive links + counts) so
  // the upload page + notify-ready don't re-walk Drive on every open. Refreshed
  // by the "ตรวจใหม่" button (refresh=1) and invalidated on upload/merge.
  footageCache     Json?
  footageCacheAt   DateTime?
  // v1.114 — id-first Drive linkage: the folder IDs the system created/resolved
  // for this booking ({ box, landing, staging, photo }). Names on Drive become
  // cosmetic — renames/moves can't break detection/merges once an ID is stored.
  // Backward compatible: null → every reader falls back to name resolution.
  driveFolders     Json?
  status           BookingStatus @default(REQUESTED)
  createdByEmail   String?
  // Cancellation REQUEST (producer/owner asks; staff actually cancels). Keeps the
  // status as-is so the queue/state machine is untouched — a non-null
  // cancelRequestedAt just flags the booking into the "ขอยกเลิก" tab.
  cancelRequestedAt DateTime?
  cancelReason      String?
  cancelRequestedBy String?
  calendarEventId  String?
  // v1.32.2 — async calendar sync visibility. Approve sets PENDING
  // before kicking off the background create; the background task
  // writes OK on success or FAILED (with calendarSyncError) on error.
  // The 10-min reconciler retries FAILED rows and updates timestamps
  // on every pass. UI surfaces this state on the admin booking cards
  // so admins see at a glance when a CONFIRMED booking is missing its
  // calendar event. Nullable: legacy bookings stay NULL until
  // start.sh's one-time backfill or the next reconciler pass.
  calendarSyncStatus    CalendarSyncStatus?
  calendarSyncError     String?
  calendarLastSyncedAt  DateTime?
  sheetRowIndex    Int?
  approvedAt       DateTime?
  // v1.51.0 — soft delete for test/junk queues: row stays in the DB (episode
  // IDs keep their sequence slots, audit history survives) but every web
  // surface filters `deletedAt: null`. ADMIN-only; restorable from the
  // Deleted tab on /admin. Hard delete (admin/[id]/delete) remains separate.
  deletedAt        DateTime?
  // v1.89 — footage delivery: the crew member presses "ส่งงาน" once footage is
  // uploaded, which emails the Producer (+CCs themselves) a file report. Last
  // delivery only (re-send allowed after uploading more). Nullable; db push.
  deliveredAt      DateTime?
  deliveredBy      String?
  // v1.56.0 — Routine bookings: recurring weekday shoots (e.g. daily news
  // THE STANDARD NOW) bulk-generated by the Routine planner. Each is a normal
  // Booking (approve/assign/calendar/OT/upload all work), but flagged so the
  // UI can badge + filter them and keep them in their own /admin tab.
  // `routineGroupId` ties one generated batch together for bulk cancel.
  isRoutine        Boolean       @default(false)
  routineGroupId   String?
  // v1.62.0 — Auto-Planning fields. The only columns the manual planning sheet
  // had that the booking system didn't; capturing them here kills the manual
  // calendar→sheet copy. All nullable — legacy bookings unaffected.
  equipmentNote        String?              // gear allocation free-text, e.g. "FX3 1, FX30 3"
  rentalGearNote       String?              // the เช่า column — rental gear for this shoot
  itinerary            String?  @db.Text    // minute-by-minute shoot breakdown
  assignedEquipmentIds String[] @default([]) // physical Equipment.id list
  outlet           Outlet        @relation(fields: [outletId], references: [id])
  outletId         String
  program          Program       @relation(fields: [programId], references: [id])
  programId        String
  episodes         Episode[]
  uploads          Upload[]
  equipmentLoans   EquipmentLoan[]
  rentalJobs       RentalJob[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([routineGroupId])
  @@map("bookings")
}

model Episode {
  id          String   @id @default(cuid())
  // NOT @unique: an episode (e.g. PP-26-006-L01) can be shot across multiple
  // Productions/bookings, so the same episodeId may appear on several rows.
  episodeId   String
  sequence    Int
  title       String
  // Per-episode business classification (non-CA bookings let the producer tag
  // each episode Original Content vs Advertorial). Reuses the booking-level
  // Category enum; only ORIGINAL_CONTENT / ADVERTORIAL are used here. Null for
  // legacy rows and Content Agency episodes (which carry it at booking level).
  contentType Category?
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId   String
  program     Program  @relation(fields: [programId], references: [id])
  programId   String
  uploads     Upload[]
  createdAt   DateTime @default(now())

  @@map("episodes")
}

// Booking change history. Best-effort: written outside the booking transaction
// to keep booking creation/update reliable. Rows older than 90 days are purged
// at app startup (start.sh). Admins get a 14-day warning banner + auto-email
// before purge so they can download a CSV report. action examples:
//   booking.create | booking.update | booking.status_change | booking.delete
//   audit.auto_email_sent | audit.purge_run
model AuditLog {
  id           String   @id @default(cuid())
  at           DateTime @default(now())
  actorEmail   String?
  action       String   @db.VarChar(64)
  entityType   String   @db.VarChar(32)
  entityId     String?
  bookingCode  String?
  fromStatus   String?  @db.VarChar(16)
  toStatus     String?  @db.VarChar(16)
  changes      Json?

  @@index([entityType, entityId])
  @@index([bookingCode])
  @@index([at])
  @@index([action])
  @@map("audit_logs")
}

model Upload {
  id          String       @id @default(cuid())
  episodeId   String?
  episode     Episode?     @relation(fields: [episodeId], references: [id])
  bookingId   String
  booking     Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  camera      String
  fileName    String
  fileSize    BigInt?
  mimeType    String?
  notes       String?
  status      UploadStatus @default(PENDING)
  uploadedBy  String

  // v1.35.0 — dual-cloud upload metadata + integrity. All nullable so old
  // pre-v1.35 rows (local-disk uploads) keep working unchanged.
  sha256        String?  // computed in browser before upload; verified on complete
  driveFileId   String?  @unique
  driveUrl      String?
  // LEGACY (Wasabi dual-write removed) — kept so historical rows keep their
  // archive pointers; no code writes these anymore.
  wasabiBucket       String?
  wasabiKey          String?  // e.g. "VIDEO2026/Advertorial/AGN-…/Cam1/001.mp4"
  wasabiMultipartId  String?  // S3 UploadId between init+complete (v1.35.1)
  wasabiEtag         String?  // final ETag from CompleteMultipartUpload
  initiatedAt   DateTime @default(now())  // when /api/upload/init was called
  completedAt   DateTime?                 // when both clouds confirmed + sheet row written
  failureReason String?                   // surfaced in admin UI for FAILED/ORPHANED rows

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@map("uploads")
}

// v1.34.1 — append-only ledger of Drive files seen by the footage-sheet
// sync worker. One row per Drive file (keyed by driveFileId), regardless
// of whether the filename parsed into a Production ID or matched a
// booking. The worker uses this for dedupe: before appending a row to
// the user's footage sheet, it checks if the file's driveFileId already
// has a FootageLog row — skips if yes.
//
// parseStatus values (kept as plain String, not enum, so we can add
// states without a Prisma migration):
//   'matched'           — filename parsed AND booking found
//   'parsed_no_booking' — filename parsed but no Booking has that code
//   'unparsed'          — filename didn't match the Production ID format
//
// productionId / bookingId stay null when the corresponding status
// signals "didn't get that far" — makes triage queries trivial.
model FootageLog {
  id              String   @id @default(cuid())
  driveFileId     String   @unique
  productionId    String?
  bookingId       String?
  filename        String
  driveUrl        String?
  parseStatus     String   @db.VarChar(32)
  sheetRowWritten Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([productionId])
  @@index([parseStatus])
  @@map("footage_log")
}

// ──────────────────────────────────────────────────────────────────────────────
// v1.62.0 — Unified admin workspace. Absorbs three manual Google Sheets
// (equipment+repair, planning, rental/purchase/finance) into the platform so a
// solo admin works in one place, with the reminder engine watching due dates.
// ──────────────────────────────────────────────────────────────────────────────

enum EquipmentCategory {
  AUDIO
  CAMERA
  COMPUTER_MONITOR
  GRIP_SUPPORT
  LENS
  LIGHTING
  POWER
  STORAGE_MEDIA
  UNCATEGORIZED
}

enum EquipmentStatus {
  AVAILABLE
  ON_LOAN
  IN_REPAIR
  RETIRED
}

enum LoanStatus {
  REQUESTED  // crew self-requested gear for their booking — awaits gear-manager checkout (does NOT lock the unit; only ACTIVE does)
  ACTIVE
  RETURNED
}

enum RepairStatus {
  REPORTED
  SENT
  RETURNED
  CANNOT_REPAIR
}

enum PaymentStatus {
  PAID      // จ่ายแล้ว
  INVOICED  // วางบิล
  PENDING   // รอจ่าย
}

enum RentalStatus {
  ACTIVE
  RETURNED
  ARCHIVED
}

// Monthly purchasing is submitted as a whole month for manager sign-off, so the
// approval state lives on the batch (the month), mirroring the OT workflow.
enum PurchaseApprovalStatus {
  DRAFT      // buyer is still adding items — not in the manager's queue
  SUBMITTED  // buyer pushed the month for approval
  APPROVED   // manager signed off
  REJECTED   // manager pushed back with rejectionNote; buyer edits + resubmits
}

enum DocKind {
  QUOTATION
  INVOICE
  TAX_INVOICE
  TRANSFER_RECEIPT
  RECEIPT
  OTHER
}

enum ReminderType {
  LOAN_DUE
  LOAN_OVERDUE
  RENTAL_RETURN_DUE
  INVOICE_AGING
  REPAIR_OUTSTANDING
  SHOOT_MISSING_GEAR
  WARRANTY_EXPIRING
}

enum ReminderStatus {
  PENDING
  SENT
  DISMISSED
  RESOLVED
}

// Physical gear inventory + the accounting fixed-asset register in one table.
// `loanable=false` (set on imported depreciation rows) hides office/building
// assets from the loan picker. Status is owned by loans, not edited by hand.
model Equipment {
  id           String            @id @default(cuid())
  itemId       String?           @unique // ITEMID from the inventory sheet
  name         String
  description  String?
  serialNumber String?
  category     EquipmentCategory @default(UNCATEGORIZED)
  location     String? // free-text: room or person, as in the sheet
  status       EquipmentStatus   @default(AVAILABLE)
  loanable     Boolean           @default(true)
  notes        String?

  // Fixed-asset register (Asset Depreciation tab) — imported as read-only
  // metadata. No depreciation calc engine: park the numbers as text.
  isFixedAsset      Boolean   @default(false)
  fixedAssetTag     String?
  purchaseDate      DateTime? @db.Date
  purchasePrice     Decimal?  @db.Decimal(12, 2)
  warrantyExpiresAt DateTime? @db.Date
  depreciationNote  String?

  loans     EquipmentLoanItem[]
  repairs   RepairTicket[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([category, status])
  @@index([loanable, status])
  @@index([warrantyExpiresAt])
  @@map("equipment")
}

model EquipmentLoan {
  id           String     @id @default(cuid())
  loanCode     String     @unique // LOAN-YYMMDDHHMM (reuses the sheet's format)
  photographer String
  email        String?
  jobName      String?
  bookingId    String?
  booking      Booking?   @relation(fields: [bookingId], references: [id])
  eventDate    DateTime?  @db.Date
  dueDate      DateTime?  @db.Date
  borrowedAt   DateTime?
  returnedAt   DateTime?
  status       LoanStatus @default(ACTIVE)

  items     EquipmentLoanItem[]
  documents DocumentRef[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([status, dueDate])
  @@index([bookingId])
  @@map("equipment_loans")
}

model EquipmentLoanItem {
  id           String        @id @default(cuid())
  loanId       String
  loan         EquipmentLoan @relation(fields: [loanId], references: [id], onDelete: Cascade)
  equipmentId  String?
  equipment    Equipment?    @relation(fields: [equipmentId], references: [id])
  nameSnapshot String // name captured at loan time (from the Items JSON)
  tagSnapshot  String?

  @@index([loanId])
  @@index([equipmentId])
  @@map("equipment_loan_items")
}

// The repair-tracking table the sheet never had (repair info was scattered in
// free-text notes). itemLabel stays free-text since today's data isn't keyed
// to inventory rows; equipmentId links it when resolvable.
model RepairTicket {
  id           String       @id @default(cuid())
  equipmentId  String?
  equipment    Equipment?   @relation(fields: [equipmentId], references: [id])
  itemLabel    String
  issue        String?
  vendorId     String?
  vendor       Vendor?      @relation(fields: [vendorId], references: [id])
  status       RepairStatus @default(REPORTED)
  sentDate     DateTime?    @db.Date
  returnedDate DateTime?    @db.Date
  cost         Decimal?     @db.Decimal(12, 2)
  kind         String? // REPLACE / ADD / FIX (sheet remark)
  remark       String?

  documents DocumentRef[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status])
  @@index([equipmentId])
  @@map("repair_tickets")
}

model Vendor {
  id          String  @id @default(cuid())
  name        String  @unique
  service     String? // CAMERA / GRIP / LIGHT / RADIO / DRONE
  contact     String? // phone
  bankAccount String?

  rentals   RentalJob[]
  repairs   RepairTicket[]
  purchases Purchase[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("vendors")
}

// Rental 2026 + Return/Archive tabs merged (one lifecycle, status separates).
// returnDueDate/returnedAt are NEW — the sheet had no return tracking, which is
// exactly what the reminder engine needs to stop forgotten returns.
model RentalJob {
  id            String        @id @default(cuid())
  quoteNo       String? // QU-xxxx
  adType        String? // AD / NON-AD
  jobName       String?
  bookingId     String?
  booking       Booking?      @relation(fields: [bookingId], references: [id])
  outletId      String?
  outlet        Outlet?       @relation(fields: [outletId], references: [id])
  vendorId      String?
  vendor        Vendor?       @relation(fields: [vendorId], references: [id])
  rentalDate    DateTime?     @db.Date
  returnDueDate DateTime?     @db.Date
  returnedAt    DateTime?     @db.Date
  paymentStatus PaymentStatus @default(PENDING)
  invoiceNo     String?
  amount        Decimal?      @db.Decimal(12, 2)
  status        RentalStatus  @default(ACTIVE)
  remark        String?
  // Resolved once on first document upload and reused, so a rental's Drive
  // folder is stable even if its booking link or rentalDate later changes
  // (mirrors Purchase.driveFolderId). Also keeps two rentals from colliding.
  driveFolderId String?

  documents DocumentRef[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([paymentStatus])
  @@index([status, returnDueDate])
  @@index([bookingId])
  @@map("rental_jobs")
}

// One month's purchasing for one buyer — the unit that gets submitted, approved,
// summed, and filed into a Drive folder. Items hang off it.
model PurchaseBatch {
  id              String                 @id @default(cuid())
  month           String                 // YYYY-MM
  ownerEmail      String                 // the buyer who owns this month's purchasing
  status          PurchaseApprovalStatus @default(DRAFT)
  submittedAt     DateTime?
  approvedByEmail String?
  approvedAt      DateTime?
  rejectionNote   String?
  // The month folder in Drive (DRIVE_DOCS_ROOT/จัดซื้อ/<month>); items get subfolders.
  driveFolderId   String?
  driveFolderUrl  String?

  items     Purchase[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([ownerEmail, month]) // one batch per buyer per month
  @@index([status])
  @@index([month])
  @@map("purchase_batches")
}

model Purchase {
  id           String        @id @default(cuid())
  batchId      String
  batch        PurchaseBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  purchaseDate DateTime?     @db.Date // the actual buy date (was only a month string before)
  item         String
  quantity     Int           @default(1)
  vendorId     String?
  vendor       Vendor?       @relation(fields: [vendorId], references: [id])
  productLink  String?
  unitPrice    Decimal?      @db.Decimal(12, 2)
  total        Decimal?      @db.Decimal(12, 2)
  kind         String? // ADD / REPLACE / FIX
  remark       String?
  driveFolderId String? // the item subfolder under the batch's month folder

  documents DocumentRef[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([batchId])
  @@map("purchases")
}

// Drive-file reference, attachable to a rental / purchase / repair / loan via
// nullable FKs (lazy polymorphism — keeps integrity + Prisma include, cheaper
// than a generic entityType/entityId table for this fixed set of owners).
model DocumentRef {
  id          String  @id @default(cuid())
  kind        DocKind @default(OTHER)
  fileName    String
  driveFileId String?
  driveUrl    String?

  rentalJobId    String?
  rentalJob      RentalJob?     @relation(fields: [rentalJobId], references: [id], onDelete: Cascade)
  purchaseId     String?
  purchase       Purchase?      @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  repairTicketId String?
  repairTicket   RepairTicket?  @relation(fields: [repairTicketId], references: [id], onDelete: Cascade)
  loanId         String?
  loan           EquipmentLoan? @relation(fields: [loanId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([rentalJobId])
  @@index([purchaseId])
  @@index([repairTicketId])
  @@index([loanId])
  @@map("document_refs")
}

// Anti-forget engine. The daily scan upserts rows keyed by dedupeKey so it
// never double-sends; the notifier dispatches PENDING rows (Discord + email)
// and marks them SENT.
model Reminder {
  id         String         @id @default(cuid())
  type       ReminderType
  status     ReminderStatus @default(PENDING)
  dueDate    DateTime?      @db.Date
  title      String
  body       String?
  dedupeKey  String         @unique // e.g. "LOAN_OVERDUE:LOAN-2601151230"
  entityType String?
  entityId   String?
  sentAt     DateTime?
  resolvedAt DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([status, type])
  @@index([dueDate])
  @@map("reminders")
}

model VendorPrice {
  id          String   @id @default(cuid())
  vendor      String
  category    String
  item        String
  spec        String?
  unit        String   @default("วัน")
  pricePerDay Decimal  @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([vendor])
  @@index([category])
  @@map("vendor_prices")
}

// Last-successful-run timestamp per background worker. The health-summary
// endpoint + the dead-man check read this to tell a dead worker (app still
// serving, worker silently gone) from a healthy one. One row per worker key.
model SystemHeartbeat {
  key  String   @id
  at   DateTime
  note String?

  @@map("system_heartbeats")
}

// v1.111 — NAS ↔ Production Team sync verification. A tiny agent on the admin's
// Mac (launchd, every 10 min) scans the SMB-mounted NAS and POSTs a manifest
// (per-folder relative paths + sizes); the server diffs it against the Drive
// landing folders. `manifest` = latest NAS snapshot; `status` = per-folder
// last-known result (complete flags + emailedAt) so "just became 100% synced"
// fires ONE email per folder, plus a daily digest.
model NasSyncState {
  key       String   @id // 'latest'
  manifest  Json
  status    Json?
  updatedAt DateTime @updatedAt

  @@map("nas_sync_state")
}
