generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ShootType {
  STUDIO
  ON_LOCATION
  REMOTE_ONLINE
  EVENT
}

enum Category {
  RECURRING
  AGENCY_JOB
  SERVICE_JOB
  INTERNAL
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum UploadStatus {
  PENDING
  UPLOADING
  COMPLETE
  FAILED
}

model Outlet {
  id       String    @id @default(cuid())
  code     String    @unique @db.VarChar(3)
  name     String
  notes    String?
  color    String?
  sort     Int       @default(0)
  programs Program[]
  bookings Booking[]

  @@map("outlets")
}

model Program {
  id       String   @id @default(cuid())
  code     String   @db.VarChar(4)
  name     String
  category String
  outlet   Outlet   @relation(fields: [outletId], references: [id])
  outletId String
  episodes Episode[]
  bookings Booking[]

  @@unique([code, outletId])
  @@map("programs")
}

model Booking {
  id              String        @id @default(cuid())
  shootDate       DateTime      @db.Date
  category        Category
  shootType       ShootType
  locationName    String?
  callTime        String        @db.VarChar(5)
  estimatedWrap   String?       @db.VarChar(5)
  producer        String
  creative        String[]
  crewRequired    String[]
  agencyRef       String?
  notes           String?
  status          BookingStatus @default(PENDING)
  outlet          Outlet        @relation(fields: [outletId], references: [id])
  outletId        String
  program         Program       @relation(fields: [programId], references: [id])
  programId       String
  episodes        Episode[]
  uploads         Upload[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("bookings")
}

model Episode {
  id          String   @id @default(cuid())
  episodeId   String   @unique
  sequence    Int
  title       String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId   String
  program     Program  @relation(fields: [programId], references: [id])
  programId   String
  uploads     Upload[]
  createdAt   DateTime @default(now())

  @@map("episodes")
}

model Upload {
  id          String       @id @default(cuid())
  episodeId   String?
  episode     Episode?     @relation(fields: [episodeId], references: [id])
  bookingId   String
  booking     Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  camera      String
  fileName    String
  fileSize    BigInt?
  mimeType    String?
  notes       String?
  status      UploadStatus @default(PENDING)
  uploadedBy  String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("uploads")
}
