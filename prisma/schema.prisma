generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ShootType {
  STUDIO
  ON_LOCATION
  REMOTE_ONLINE
  EVENT
}

enum Category {
  RECURRING
  AGENCY_JOB
  SERVICE_JOB
  INTERNAL
}

enum BookingStatus {
  REQUESTED
  ASSIGNED
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum UploadStatus {
  PENDING
  UPLOADING
  COMPLETE
  FAILED
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  thaiName   String?  // ชื่อ-นามสกุลภาษาไทย
  employeeId String?  // TSD00xxx
  position   String?  // Producer / Videographer / etc
  role       UserRole @default(USER)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("users")
}

enum OTType {
  HOLIDAY  // เสาร์-อาทิตย์ / วันหยุดตามประกาศบริษัท (counts as 1 day)
  OVERTIME // ทำงานเกิน 8 ชั่วโมง (counts hours)
}

enum OTApprovalStatus {
  PENDING   // logged by the user, awaiting manager sign-off
  APPROVED  // signed off by an admin/manager
}

model OTRecord {
  id              String   @id @default(cuid())
  userEmail       String
  month           String   // YYYY-MM, derived from date
  date            DateTime @db.Date

  // Task-level fields (new model — required for new entries)
  startTime       String?  @db.VarChar(5)  // HH:MM
  endTime         String?  @db.VarChar(5)  // HH:MM
  jobTask         String?  // description of work performed
  justification   String?  // why OT/standby was necessary

  // Approval — manager/admin signs off the report per person per month
  approvalStatus  OTApprovalStatus @default(PENDING)
  approvedByEmail String?
  approvedAt      DateTime?

  // Legacy fields (kept for backward compat with old data; not used for new entries)
  type            OTType?
  hours           Float    @default(0)
  description     String?

  bookingId       String?  // if auto-generated from a booking, the booking id (null = manual)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userEmail, month])
  @@index([month])
  @@index([bookingId])
  @@index([approvalStatus])
  @@map("ot_records")
}

model Outlet {
  id       String    @id @default(cuid())
  code     String    @unique @db.VarChar(3)
  name     String
  notes    String?
  color    String?
  sort     Int       @default(0)
  programs Program[]
  bookings Booking[]

  @@map("outlets")
}

model Program {
  id       String    @id @default(cuid())
  code     String    @db.VarChar(4)
  name     String
  category String
  outlet   Outlet    @relation(fields: [outletId], references: [id])
  outletId String
  episodes Episode[]
  bookings Booking[]

  @@unique([code, outletId])
  @@map("programs")
}

model Booking {
  id               String        @id @default(cuid())
  shootDate        DateTime      @db.Date
  shootEndDate     DateTime?     @db.Date   // null = single-day shoot
  category         Category
  shootType        ShootType
  locationName     String?
  callTime         String        @db.VarChar(5)
  estimatedWrap    String?       @db.VarChar(5)
  producer         String   // Content Agency: nickname from _Users tab; other outlets: free-text name
  producerEmail    String?  // Producer email (canonical id, or free-text email)
  producerPhone    String?  // Producer phone — free-text outlets only (Content Agency uses _Users)
  director         String?  // Director nickname (Content Agency only — null for other outlets)
  directorEmail    String?  // Director email (canonical id)
  creative         String[]
  crewRequired     String[]
  videographerCount     Int     @default(1)  // how many videographers requested at booking time
  assignedEmails   String[]
  mainVideographerEmail String?              // designated lead camera, picked at assign-time
  agencyRef        String?
  // Project ID layer — links booking to Producer Dashboard "All Projects".
  // Format PP-YY-NNN (e.g. PP-26-001). Immutable. projectName is a snapshot
  // captured at booking time so we can render without re-fetching the sheet.
  projectId        String?
  projectName      String?
  notes            String?
  adminNotes       String?
  status           BookingStatus @default(REQUESTED)
  createdByEmail   String?
  calendarEventId  String?
  sheetRowIndex    Int?
  approvedAt       DateTime?
  outlet           Outlet        @relation(fields: [outletId], references: [id])
  outletId         String
  program          Program       @relation(fields: [programId], references: [id])
  programId        String
  episodes         Episode[]
  uploads          Upload[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@map("bookings")
}

model Episode {
  id          String   @id @default(cuid())
  episodeId   String   @unique
  sequence    Int
  title       String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId   String
  program     Program  @relation(fields: [programId], references: [id])
  programId   String
  uploads     Upload[]
  createdAt   DateTime @default(now())

  @@map("episodes")
}

model Upload {
  id          String       @id @default(cuid())
  episodeId   String?
  episode     Episode?     @relation(fields: [episodeId], references: [id])
  bookingId   String
  booking     Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  camera      String
  fileName    String
  fileSize    BigInt?
  mimeType    String?
  notes       String?
  status      UploadStatus @default(PENDING)
  uploadedBy  String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("uploads")
}
