# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/production_booking"

# Next.js
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="THE STANDARD Production Booking"

# Email delivery
# Render free web services block outbound SMTP ports 25/465/587.
# The app can send through the logged-in admin's Google account after the admin
# signs in with Gmail send permission. Optional HTTP providers are also supported:
# EMAIL_PROVIDER="resend"
# RESEND_API_KEY="re_xxx"
# EMAIL_FROM="THE STANDARD Production Booking <production@thestandard.co>"
#
# Optional SendGrid HTTP API alternative:
# EMAIL_PROVIDER="sendgrid"
# SENDGRID_API_KEY="SG.xxx"
# EMAIL_FROM="THE STANDARD Production Booking <production@thestandard.co>"
#
# SMTP fallback (works only where outbound SMTP is allowed, or with a provider port like 2525):
# EMAIL_PROVIDER="smtp"
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="465"
# SMTP_SECURE="true"
# SMTP_USER="production@thestandard.co"
# SMTP_PASS="app-password"
# SMTP_FROM="THE STANDARD Production Booking <production@thestandard.co>"

# ── Reminder engine (v1.62.0) ─────────────────────────────────────────────────
# Daily "กันลืม" scan → Discord + email digest. The worker stays OFF until enabled.
# REMINDERS_WORKER_ENABLED="1"
# DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/xxx/yyy"   # primary push channel
# REMINDER_ADMIN_EMAIL="narasit.k@thestandard.co"                  # digest recipient
#   NOTE: the email digest needs a non-interactive provider (SMTP/Resend/SendGrid)
#   above — the worker has no logged-in user, so Gmail-OAuth is unavailable to it.
#   Discord works with just the webhook URL.
# REMINDERS_SECRET="<defaults to NEXTAUTH_SECRET>"                 # gates /api/internal/reminders/run
# Optional tuning (defaults shown):
# REMINDERS_WORKER_INTERVAL_MS="86400000"   # 24h
# INVOICE_AGING_DAYS="7"
# SHOOT_GEAR_LOOKAHEAD_DAYS="3"
# LOAN_DUE_LOOKAHEAD_DAYS="2"
# REPAIR_AGING_DAYS="7"
# WARRANTY_LOOKAHEAD_DAYS="30"
