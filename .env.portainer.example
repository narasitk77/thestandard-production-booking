# Portainer Stack Environment Variables
# Paste these into Portainer → Stacks → Add stack → Environment variables
# (or upload as .env). Replace every <...> placeholder before saving.

# ─── Database ──────────────────────────────────────────────────────────────────
# Only POSTGRES_PASSWORD is configurable — db name (production_booking) and
# user (prod_booking) are hardcoded in docker-compose.portainer.yml so a typo
# can't break the stack. Override only if you know what you're doing.
POSTGRES_PASSWORD=<choose-a-strong-password>

# ─── Host port (the port exposed by Portainer host; pick anything free) ────────
APP_PORT=3001

# ─── Public URL (must match Google OAuth Authorized redirect URI) ──────────────
# Examples:
#   http://thestandard.fortiddns.com:3001
#   https://booking.thestandard.co
NEXTAUTH_URL=http://thestandard.fortiddns.com:3001
NEXT_PUBLIC_APP_URL=http://thestandard.fortiddns.com:3001
NEXTAUTH_SECRET=<run: openssl rand -base64 32>

# ─── Google OAuth (sign-in + Gmail send) ───────────────────────────────────────
# Same Client ID/Secret currently used on Render — but you MUST add the new
# redirect URI to the Google Cloud Console OAuth client:
#     ${NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=<from-google-cloud-console>
GOOGLE_CLIENT_SECRET=<from-google-cloud-console>

# ─── Google Service Account (Sheets + Calendar automation) ─────────────────────
# Either provide JSON blob OR email + private key (whichever the Render env uses)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=
# Domain-Wide Delegation: a @thestandard.co user to impersonate so the service
# account can add assigned crew as calendar GUESTS + send invites. Needs DWD
# enabled in Workspace Admin (scope https://www.googleapis.com/auth/calendar).
# Leave blank → crew listed in the event description only (no guests).
GOOGLE_IMPERSONATE_SUBJECT=

# ─── Producer Dashboard / Episode-ID Web App ───────────────────────────────────
# PRODUCER_DASHBOARD_SHEET_ID — the sheet the booking app reads projects/
# episodes/_Users from. Leave blank to use the production master sheet
# (10TnR03z...). Set to the pilot copy's ID while testing.
PRODUCER_DASHBOARD_SHEET_ID=

# (Project Episode IDs are now minted in-app and written to the Producer
# Dashboard sheet via the Google service account — no Apps Script Web App.
# The old BOOKING_EPISODE_WEBAPP_URL / _SECRET vars are no longer used.)

# ─── Email delivery (optional fallbacks; Gmail OAuth works out-of-the-box) ─────
# Leave blank to rely solely on signed-in admin's Google account.
# Recommended fallback: Resend (3,000 emails/month free)
EMAIL_FROM=
EMAIL_PROVIDER=
RESEND_API_KEY=

# ─── v1.34.1 — Footage-log sheet (Drive → sheet auto-matcher) ──────────────────
# Sheet that the footage sync worker writes rows into. Must be shared as
# Editor to GOOGLE_SERVICE_ACCOUNT_EMAIL. The worker only writes to row 2+;
# row 1 (the header) stays untouched. Run `npx tsx scripts/inspect-footage-sheet.ts`
# once after configuring to confirm the worker can map your columns.
FOOTAGE_LOG_SHEET_ID=
# Tab name inside the sheet above. Default 'Sheet1' if blank.
FOOTAGE_LOG_TAB=

# Shared Drive folder ID — root of the tree the worker recursively scans
# every FOOTAGE_WORKER_INTERVAL_MS. The DWD-impersonated user
# (GOOGLE_IMPERSONATE_SUBJECT) must have read access to this folder.
# Layout under this root is per-outlet, mirroring Wasabi:
#   <root>/<OUTLET_CODE>/<bookingCode>/<camera>/<filename>
# e.g.  0APhGxxryY4pzUk9PVA/AGN/AGN-260423-EVT-01/Cam1/001.mp4
DRIVE_FOOTAGE_ROOT=0APhGxxryY4pzUk9PVA

# Worker on/off switch. Default off so v1.34.1 can ship the library code
# without scanning anything. Flip to '1' in the Portainer stack env once
# the inspect script confirms column mapping + DRIVE_FOOTAGE_ROOT is set.
FOOTAGE_WORKER_ENABLED=0
# Scan interval in ms. Default 600000 = 10 min (matches calendar-reconcile).
FOOTAGE_WORKER_INTERVAL_MS=600000

# ─── v1.35.0 — Wasabi S3 archive (dual-cloud upload) ──────────────────────────
# Required for outlets with storagePolicy=DUAL_WRITE (default: AGN, TSS, NWS).
# The booking upload UI uses these to presign multipart PUT URLs so the
# browser uploads directly to Wasabi — server never touches the bytes.
#
# Get credentials from the Wasabi console → Access Keys → Create. The
# access key needs s3:PutObject, s3:AbortMultipartUpload, s3:ListBucket
# scoped to the bucket below.
WASABI_ENDPOINT=https://s3.ap-southeast-1.wasabisys.com
WASABI_REGION=ap-southeast-1
WASABI_BUCKET=video2026hires
# Bucket-level prefix prepended to every key. Lets a single bucket host
# multiple years/projects. Layout:
#   <prefix>/<OUTLET_CODE>/<bookingCode>/<camera>/<filename>
# e.g.  VIDEO2026/AGN/AGN-260423-EVT-01/Cam1/001.mp4
WASABI_KEY_PREFIX=VIDEO2026
# Inject these via Portainer stack env directly — never paste into
# .env files or any plaintext that ends up in git history or chat.
WASABI_ACCESS_KEY=
WASABI_SECRET_KEY=
# Set to '1' to require BOTH clouds even for DRIVE_ONLY outlets when the
# operator opts in via the per-file Wasabi checkbox. Default '1'.
WASABI_VERIFY_ON_COMPLETE=1

# ── MCP — let external AI clients operate the app (v1.49.0, docs/mcp.md) ──
# Bearer key external MCP clients must send (Authorization: Bearer <key>).
# UNSET = the /api/mcp endpoint is disabled (503). Generate with:
#   openssl rand -hex 32
MCP_API_KEY=
# Identity recorded in the audit trail for actions done via MCP.
MCP_ACTOR_EMAIL=mcp@thestandard.co

# ── v1.127 — video-merge worker gated on the NAS Cloud Sync (sync จบคือจบ) ──
# The worker polls the Synology DSM Cloud Sync API and runs the video merge the
# moment the sync turns GREEN (uptodate). Leave the NAS_DSM_* vars blank → the
# worker still runs, but on a plain hourly interval instead of the sync signal.
#
# DSM account: create a DEDICATED user in the "administrators" group (Cloud Sync
# status is admin-scoped), deny it every shared folder + every app except DSM,
# exempt it from 2FA, and firewall it to this stack's host IP.
# The container must be able to reach the NAS IP (same LAN / routed VLAN).
NAS_DSM_URL=https://192.168.21.220:5001
NAS_DSM_USER=
NAS_DSM_PASS=
# Optional: Cloud Sync task display name to watch (as shown in the Cloud Sync UI).
# Blank = the single Google Drive connection, else the global tray status.
NAS_DSM_CONN_NAME=
# Self-signed cert on :5001 is accepted by default; set 0 to require a valid cert.
NAS_DSM_INSECURE_TLS=1
# Cadence knobs (ms): DSM poll / min gap between merge runs / safety re-run.
VIDEO_MERGE_POLL_MS=60000
VIDEO_MERGE_MIN_GAP_MS=600000
VIDEO_MERGE_FALLBACK_MS=21600000
# Discord webhook for the "sync เขียว → merge เสร็จ" ping (shared with reminders).
DISCORD_WEBHOOK_URL=
